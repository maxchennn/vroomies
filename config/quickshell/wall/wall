#!/usr/bin/env bash
set -euo pipefail

WALLPAPER_DIR="$HOME/Pictures/Alice"
SYMLINK_PATH="$HOME/.config/hypr/current_wallpaper"
IMAGE_EXTENSIONS=("jpg" "jpeg" "png" "gif" "webp")

is_image() {
    local f="$1"
    for ext in "${IMAGE_EXTENSIONS[@]}"; do
        [[ "${f,,}" == *.$ext ]] && return 0
    done
    return 1
}

reload_service() {
    case "$1" in
        hyprpaper)
            pkill hyprpaper 2>/dev/null || true
            sleep 0.2
            hyprpaper &
            ;;
        swaync)
            pkill swaync 2>/dev/null || true
            sleep 0.2
            swaync 2>/dev/null &
            ;;
        waybar)
            pkill waybar 2>/dev/null || true
            sleep 0.2
            waybar &
            ;;
        quickshell)
            pkill quickshell 2>/dev/null || true
            sleep 0.2
            quickshell --path "$HOME/.config/quickshell/shell.qml" &
            ;;
    esac
}

SELECTED_PATH="${1:-}"

if [[ -z "$SELECTED_PATH" ]]; then
    quickshell --path "$HOME/.config/quickshell/wall/wall.qml" &
    exit 0
fi

matugen image "$SELECTED_PATH" --source-color-index 0

mkdir -p "$(dirname "$SYMLINK_PATH")"
ln -sf "$SELECTED_PATH" "$SYMLINK_PATH"

MONITOR=$(hyprctl monitors -j | jq -r '.[] | select(.focused==true).name')
hyprctl hyprpaper preload "$SELECTED_PATH"
hyprctl hyprpaper wallpaper "$MONITOR,$SELECTED_PATH"
hyprctl hyprpaper unload all

reload_service swaync
reload_service waybar
reload_service quickshell
