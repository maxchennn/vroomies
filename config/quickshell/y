import QtQuick 
import QtQuick.Controls 
import Quickshell
import Quickshell.Wayland

PanelWindow {
    id: dockWindow

    WlrLayershell.layer: WlrLayer.Top
    WlrLayershell.namespace: "Zen-Dock"
    WlrLayershell.keyboardFocus: WlrKeyboardFocus.None

    // Tüm ekranı kapla ki o dış çerçeveyi (gap) çizebilelim
    anchors {
        fill: true
    }

    color: "transparent"
    
    // Pencerelerin dock'un üstüne binmemesi için alt tarafta yer ayır
    exclusiveZone: Math.round(Screen.height * 0.055)

    // --- EKRANI ÇEVRELEYEN İÇ ÇERÇEVE (Çizimdeki o içteki yamuk çizgiler) ---
    Rectangle {
        id: screenFrame
        anchors.fill: parent
        // Ekranın kenarlarından ne kadar içeride olsun? (Çizimdeki boşluk)
        anchors.margins: 10 
        color: "transparent"
        border.color: "#313244" // İnce bir çerçeve istersen renk ver, istemezsen transparent yap
        border.width: 0
        radius: 12 // Ekran köşelerinin yuvarlaklığı
    }

    // --- DOCK (Çizimdeki o alt orta tepe) ---
    Rectangle {
        id: mainDockBody
        // Çerçevenin en altına yapıştır
        anchors.bottom: screenFrame.bottom 
        anchors.horizontalCenter: parent.horizontalCenter
        
        width: dockContent.width + Math.round(Screen.width * 0.02)
        height: Math.round(Screen.height * 0.051)
        
        color: "#000000" // Çizimdeki gibi siyah
        
        // Sadece üst köşeler yuvarlak (Radius)
        radius: 20

        // Alt köşeleri düzleme hilesi (Çizimdeki alt düz çizgi için)
        Rectangle {
            anchors.bottom: parent.bottom
            anchors.left: parent.left
            anchors.right: parent.right
            height: parent.radius
            color: parent.color
            z: -1
        }

        // Üst cam efekti
        Rectangle {
            anchors.top: parent.top
            anchors.left: parent.left
            anchors.right: parent.right
            height: parent.height / 2
            topLeftRadius: parent.radius
            topRightRadius: parent.radius
            color: "#0cffffff"
        }

        Row {
            id: dockContent
            anchors.centerIn: parent
            spacing: Math.round(Screen.width * 0.008)

            Component.onCompleted: {
                var apps = ["󰈹:firefox", "󰆍:foot", "󰉋:thunar", "󰓓:steam", "󰙯:discord"]
                for (var i = 0; i < apps.length; i++) {
                    var parts = apps[i].split(":")
                    dockIconComp.createObject(dockContent, {
                        icon: parts[0],
                        exec: parts[1]
                    })
                }
            }
        }
    }

    Component {
        id: dockIconComp
        Item {
            property string icon: ""
            property string exec: ""
            width: Math.round(Screen.height * 0.038)
            height: Math.round(Screen.height * 0.038)

            Text {
                anchors.centerIn: parent
                text: icon
                font.pixelSize: Math.round(Screen.height * 0.026)
                color: "#ffffff"
                font.family: "Symbols Nerd Font"
                opacity: mouse.containsMouse ? 1.0 : 0.75
                Behavior on opacity { NumberAnimation { duration: 150 } }
            }

            MouseArea {
                id: mouse
                anchors.fill: parent
                hoverEnabled: true
                onClicked: Quickshell.execDetached(["bash", "-c", exec])
            }

            scale: mouse.containsMouse ? 1.3 : 1.0
            Behavior on scale {
                NumberAnimation {
                    duration: 200
                    easing.type: Easing.OutBack
                }
            }
        }
    }
}
